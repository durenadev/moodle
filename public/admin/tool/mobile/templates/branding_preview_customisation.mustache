{{!
    @template tool_mobile/branding_preview_customisation

    Embedded branding preview for the customisation animation.

    Context variables required for this template:
    * none

    Example context (json):
    {}
}}

<div class="tool-mobile-branding-preview" aria-hidden="true">
    <div class="tool-mobile-branding-preview_scene">
        <div class="tool-mobile-branding-preview_picker">
            <div class="tool-mobile-branding-preview_row">
                <div class="tool-mobile-branding-preview_pill tool-mobile-branding-preview_pill--wide"></div>
                <div class="tool-mobile-branding-preview_dot"></div>
            </div>
            <div class="tool-mobile-branding-preview_swatches">
                <div class="tool-mobile-branding-preview_swatch tool-mobile-branding-preview_swatch--a"></div>
                <div class="tool-mobile-branding-preview_swatch tool-mobile-branding-preview_swatch--b"></div>
                <div class="tool-mobile-branding-preview_swatch tool-mobile-branding-preview_swatch--c"></div>
            </div>
            <div class="tool-mobile-branding-preview_gradient">
                <div class="tool-mobile-branding-preview_cursor"></div>
            </div>
            <div class="tool-mobile-branding-preview_row">
                <div class="tool-mobile-branding-preview_pill tool-mobile-branding-preview_pill--mid"></div>
                <div class="tool-mobile-branding-preview_pill tool-mobile-branding-preview_pill--small"></div>
            </div>
        </div>

        <div class="tool-mobile-branding-preview_phone">
            <div class="tool-mobile-branding-preview_header">
                <div class="tool-mobile-branding-preview_header-pill"></div>
                <div class="tool-mobile-branding-preview_header-dot"></div>
            </div>
            <div class="tool-mobile-branding-preview_list">
                <div class="tool-mobile-branding-preview_card">
                    <div class="tool-mobile-branding-preview_card-pill"></div>
                    <div class="tool-mobile-branding-preview_card-pill tool-mobile-branding-preview_card-pill--secondary"></div>
                    <div class="tool-mobile-branding-preview_bar"></div>
                </div>
                <div class="tool-mobile-branding-preview_card">
                    <div class="tool-mobile-branding-preview_card-pill tool-mobile-branding-preview_card-pill--short"></div>
                    <div class="tool-mobile-branding-preview_card-pill tool-mobile-branding-preview_card-pill--secondary tool-mobile-branding-preview_card-pill--secondary-short"></div>
                    <div class="tool-mobile-branding-preview_bar tool-mobile-branding-preview_bar--short"></div>
                </div>
            </div>
            <div class="tool-mobile-branding-preview_button">
                <div class="tool-mobile-branding-preview_button-label"></div>
            </div>
        </div>
    </div>
</div>