{{!
    @template tool_mobile/branding_customisation

    Branding and customisation preview block for the Mobile tool settings.

    Classes required for JS:
    * none

    Data attributes required for JS:
    * none

    Context variables required for this template:
    * link Optional URL displayed below the preview.

    Example context (json):
    {
        "link": "https://apps.moodle.com",
        "learnmore": 1
    }
}}
<div class="form-item row" id="admin-mobilecssurl">
    <div class="form-label col-sm-3 text-sm-end">
        <div>
            {{#str}} brandingandcustomisation, tool_mobile {{/str}}
        </div>
    </div>
    <div class="form-setting col-sm-9">
        <div class="form-text mt-2">
            <div class="row g-4">
                <div class="col-12 col-lg-8 col-xl-6 text-center mb-3">
                    <div class="tool-mobile-branding-preview-wrapper">
                        <div class="rounded overflow-hidden border">
                            {{> tool_mobile/branding_preview_customisation}}
                        </div>

                        {{#learnmore}}
                        <div class="mt-1 small text-muted">
                            {{#str}} brandingbrandcoloursacrosstheapp, tool_mobile {{/str}}
                            <a href="{{link}}" rel="noopener noreferrer"
                                aria-label="{{#str}} brandingbrandcoloursacrosstheapplearnmore, tool_mobile {{/str}}">
                                {{#str}} learnmore, tool_mobile {{/str}}
                            </a>
                        </div>
                        {{/learnmore}}
                        {{^learnmore}}
                        <div class="mt-1 small">
                            <a href="{{link}}" rel="noopener noreferrer" target="_blank"
                                aria-label="{{#str}} brandinginappsportal, tool_mobile {{/str}} ({{#str}} opensinnewwindow, core {{/str}})">
                                {{#str}} brandinginappsportal, tool_mobile {{/str}}
                                <i class="fa fa-external-link pl-1" role="img" aria-label="{{#str}} opensinnewwindow, core {{/str}}"
                                    title="{{#str}} opensinnewwindow, core {{/str}}">
                                </i>
                            </a>
                        </div>
                        {{/learnmore}}
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

