{{!
    @template tool_mobile/additional_html_alert

    Additional HTML alert shown in the Additional HTML admin settings page.

    Classes required for JS:
    * none

    Data attributes required for JS:
    * none

    Context variables required for this template:
    * title Alert title.
    * message Alert body.
    * buttonstr Button text.
    * buttonurl Button URL.

    Example context (json):
    {
        "title": "Matomo can track the Moodle app too",
        "message": "You have set up Matomo for your site. With a Premium plan, your Matomo instance can also track how learners use the Moodle app.",
        "buttonstr": "Learn more",
        "buttonurl": "https://example.com/admin/tool/mobile/subscription.php"
    }
}}
<div class="card border-0 mb-4 tool_mobile-settings-alert">
    <div class="card-body bg-primary bg-opacity-10 border rounded-4 py-4 px-4">
        <div class="d-flex align-items-center gap-3 mb-3">
            <i class="fa-solid fa-chart-line flex-shrink-0 text-primary fs-5" aria-hidden="true"></i>
            <div class="fs-6 mb-0">{{title}}</div>
        </div>
            <div class="mb-3 small text-body">{{message}}</div>
        {{#buttonstr}}
        <a href="{{buttonurl}}" class="btn btn-primary">{{buttonstr}}</a>
        {{/buttonstr}}
    </div>
</div>