{{!
    @template tool_mobile/setting_sistem_alert

    System setting alert with a right-side mobile app preview animation.

    Classes required for JS:
    * none

    Data attributes required for JS:
    * none

    Context variables required for this template:
    * iconclass Font Awesome icon classes.
    * title Alert title.
    * message Alert body.
    * buttonstr Button text.
    * buttonurl Button URL.

    Example context (json):
    {
        "iconclass": "fa-solid fa-mobile-button",
        "title": "Your logo can appear in the Moodle app too",
        "message": "Give learners a consistent branded experience across your site and mobile with a Premium plan.",
        "buttonstr": "Learn more",
        "buttonurl": "https://example.com/admin/tool/mobile/subscription.php"
    }
}}
<div class="card border rounded-4 overflow-hidden mb-4 tool_mobile-settings-alert tool-mobile-system-alert-wrapper">
    <div class="row g-0 align-items-stretch">
        <div class="col-12 col-lg-8 bg-primary bg-opacity-10 py-5 px-5">
                <div class="d-flex align-items-center gap-3 mb-3">
                    <i class="{{iconclass}} flex-shrink-0 text-primary fs-5" aria-hidden="true"></i>
                    <div class="fs-6 mb-0">{{title}}</div>
                </div>
                <div class="mb-3 small text-body">{{message}}</div>
                {{#buttonstr}}
                <a href="{{buttonurl}}" class="btn btn-primary tool-mobile-system-alert-trigger">{{buttonstr}}</a>
                {{/buttonstr}}
        </div>
        <div class="col-12 col-lg-4 text-center">
            <div class="tool-mobile-system-alert-animation">
                    {{> tool_mobile/logo_animation}}
            </div>
        </div>
    </div>
</div>

{{#js}}
(function() {
    var styleid = 'tool-mobile-system-alert-styles';
    if (document.getElementById(styleid)) {
        return;
    }

    var style = document.createElement('style');
    style.id = styleid;
    style.textContent = '.tool-mobile-system-alert-wrapper {' +
        'border-color:#d5d4dc !important;}' +
        '.tool-mobile-system-alert-animation {' +
        'background:#ececed;' +
        '--tool-mobile-logo-preview-unit:clamp(0.72px, 0.08vw + 0.56px, 1px);' +
        '--tool-mobile-logo-preview-cycle:6s;' +
        'padding:calc(1 * var(--tool-mobile-logo-preview-unit)) calc(1 * var(--tool-mobile-logo-preview-unit)) 0;' +
        'height:calc(230 * var(--tool-mobile-logo-preview-unit));' +
        'display:flex;align-items:flex-end;justify-content:center;overflow:hidden;}' +
        '.tool-mobile-logo-preview {font-family:-apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;display:flex;align-items:flex-end;justify-content:center;width:100%;height:100%;}' +
        '.tool-mobile-logo-preview_phone {width:calc(190 * var(--tool-mobile-logo-preview-unit));background:#fff;border-radius:calc(22 * var(--tool-mobile-logo-preview-unit)) calc(22 * var(--tool-mobile-logo-preview-unit)) 0 0;box-shadow:0 0 0 calc(4 * var(--tool-mobile-logo-preview-unit)) #f7f7f8, 0 calc(16 * var(--tool-mobile-logo-preview-unit)) calc(40 * var(--tool-mobile-logo-preview-unit)) rgba(0,0,0,0.10);display:flex;flex-direction:column;padding:calc(10 * var(--tool-mobile-logo-preview-unit)) calc(11 * var(--tool-mobile-logo-preview-unit)) 0;transform:translateY(calc(60 * var(--tool-mobile-logo-preview-unit)));}' +
        '.tool-mobile-logo-preview_statusbar {display:flex;align-items:center;justify-content:space-between;margin-bottom:calc(9 * var(--tool-mobile-logo-preview-unit));}' +
        '.tool-mobile-logo-preview_notch {width:calc(26 * var(--tool-mobile-logo-preview-unit));height:calc(8 * var(--tool-mobile-logo-preview-unit));background:#2c2c2e;border-radius:calc(5 * var(--tool-mobile-logo-preview-unit));}' +
        '.tool-mobile-logo-preview_statusicons {display:flex;gap:calc(3 * var(--tool-mobile-logo-preview-unit));align-items:center;}' +
        '.tool-mobile-logo-preview_statusicon {display:block;background:#2c2c2e;border-radius:calc(1 * var(--tool-mobile-logo-preview-unit));}' +
        '.tool-mobile-logo-preview_statusicon--signal {width:calc(8 * var(--tool-mobile-logo-preview-unit));height:calc(5 * var(--tool-mobile-logo-preview-unit));clip-path:polygon(0 100%,100% 0,100% 100%);}' +
        '.tool-mobile-logo-preview_statusicon--wifi {width:calc(7 * var(--tool-mobile-logo-preview-unit));height:calc(5 * var(--tool-mobile-logo-preview-unit));border-radius:50% 50% 0 0 !important;}' +
        '.tool-mobile-logo-preview_statusicon--battery {width:calc(11 * var(--tool-mobile-logo-preview-unit));height:calc(6 * var(--tool-mobile-logo-preview-unit));border-radius:calc(2 * var(--tool-mobile-logo-preview-unit)) !important;}' +
        '.tool-mobile-logo-preview_navrow {display:flex;align-items:center;justify-content:space-between;padding-bottom:calc(8 * var(--tool-mobile-logo-preview-unit));border-bottom:1px solid #eeeef0;margin-bottom:calc(16 * var(--tool-mobile-logo-preview-unit));}' +
        '.tool-mobile-logo-preview_navleft {display:flex;align-items:center;gap:calc(7 * var(--tool-mobile-logo-preview-unit));}' +
        '.tool-mobile-logo-preview_backarrow {font-size:calc(10 * var(--tool-mobile-logo-preview-unit));color:#3b3b40;}' +
        '.tool-mobile-logo-preview_navpill {width:calc(38 * var(--tool-mobile-logo-preview-unit));height:calc(7 * var(--tool-mobile-logo-preview-unit));background:#d8d8dc;border-radius:999px;}' +
        '.tool-mobile-logo-preview_navicons {display:flex;gap:calc(8 * var(--tool-mobile-logo-preview-unit));align-items:center;font-size:calc(10 * var(--tool-mobile-logo-preview-unit));color:#3d3d8f;}' +
        '.tool-mobile-logo-preview_logowrap {display:flex;justify-content:center;margin-bottom:calc(15 * var(--tool-mobile-logo-preview-unit));}' +
        '.tool-mobile-logo-preview_logotile {width:calc(64 * var(--tool-mobile-logo-preview-unit));height:calc(64 * var(--tool-mobile-logo-preview-unit));border-radius:calc(16 * var(--tool-mobile-logo-preview-unit));position:relative;box-shadow:0 0 0 calc(4 * var(--tool-mobile-logo-preview-unit)) rgba(130,130,225,0.16);}' +
        '.tool-mobile-logo-preview_brand {position:absolute;inset:0;border-radius:calc(16 * var(--tool-mobile-logo-preview-unit));display:flex;align-items:center;justify-content:center;opacity:0;animation:tool-mobile-logo-preview-swap var(--tool-mobile-logo-preview-cycle) infinite;animation-play-state:paused;}' +
        '.tool-mobile-logo-preview_brand--a {background:#3cb878;animation-delay:0s;}' +
        '.tool-mobile-logo-preview_brand--b {background:linear-gradient(145deg, #e05252, #c23434);animation-delay:-2s;}' +
        '.tool-mobile-logo-preview_brand--c {background:linear-gradient(145deg, #7b6cf0, #5a48d8);animation-delay:-4s;}' +
        '.tool-mobile-logo-preview_mountain {width:calc(33 * var(--tool-mobile-logo-preview-unit));height:calc(21 * var(--tool-mobile-logo-preview-unit));position:relative;overflow:hidden;}' +
        '.tool-mobile-logo-preview_mountain::before,.tool-mobile-logo-preview_mountain::after {content:"";position:absolute;bottom:0;border-left:calc(11 * var(--tool-mobile-logo-preview-unit)) solid transparent;border-right:calc(11 * var(--tool-mobile-logo-preview-unit)) solid transparent;border-bottom:calc(17 * var(--tool-mobile-logo-preview-unit)) solid rgba(255,255,255,0.95);}' +
        '.tool-mobile-logo-preview_mountain::before {left:calc(1 * var(--tool-mobile-logo-preview-unit));}' +
        '.tool-mobile-logo-preview_mountain::after {left:calc(13 * var(--tool-mobile-logo-preview-unit));border-bottom-color:rgba(255,255,255,0.65);}' +
        '.tool-mobile-logo-preview_flower {width:calc(33 * var(--tool-mobile-logo-preview-unit));height:calc(33 * var(--tool-mobile-logo-preview-unit));position:relative;}' +
        '.tool-mobile-logo-preview_petal {position:absolute;width:calc(14 * var(--tool-mobile-logo-preview-unit));height:calc(14 * var(--tool-mobile-logo-preview-unit));background:#fff;border-radius:50%;}' +
        '.tool-mobile-logo-preview_petal:nth-child(1) {top:0;left:calc(9 * var(--tool-mobile-logo-preview-unit));}' +
        '.tool-mobile-logo-preview_petal:nth-child(2) {bottom:0;left:calc(9 * var(--tool-mobile-logo-preview-unit));}' +
        '.tool-mobile-logo-preview_petal:nth-child(3) {left:0;top:calc(9 * var(--tool-mobile-logo-preview-unit));}' +
        '.tool-mobile-logo-preview_petal:nth-child(4) {right:0;top:calc(9 * var(--tool-mobile-logo-preview-unit));}' +
        '.tool-mobile-logo-preview_flowercentre {position:absolute;top:calc(12 * var(--tool-mobile-logo-preview-unit));left:calc(12 * var(--tool-mobile-logo-preview-unit));width:calc(10 * var(--tool-mobile-logo-preview-unit));height:calc(10 * var(--tool-mobile-logo-preview-unit));background:#c23434;border-radius:50%;box-shadow:0 0 0 calc(2 * var(--tool-mobile-logo-preview-unit)) #fff;}' +
        '.tool-mobile-logo-preview_orbit {width:calc(33 * var(--tool-mobile-logo-preview-unit));height:calc(33 * var(--tool-mobile-logo-preview-unit));position:relative;}' +
        '.tool-mobile-logo-preview_orbit::before {content:"";position:absolute;inset:calc(6 * var(--tool-mobile-logo-preview-unit));border:calc(3 * var(--tool-mobile-logo-preview-unit)) solid rgba(255,255,255,0.95);border-radius:50%;transform:rotate(-25deg) scaleY(0.62);}' +
        '.tool-mobile-logo-preview_orbit::after {content:"";position:absolute;top:calc(5 * var(--tool-mobile-logo-preview-unit));right:calc(4 * var(--tool-mobile-logo-preview-unit));width:calc(7 * var(--tool-mobile-logo-preview-unit));height:calc(7 * var(--tool-mobile-logo-preview-unit));background:#fff;border-radius:50%;}' +
        '.tool-mobile-logo-preview_titles {display:flex;flex-direction:column;align-items:center;gap:calc(6 * var(--tool-mobile-logo-preview-unit));margin-bottom:calc(16 * var(--tool-mobile-logo-preview-unit));}' +
        '.tool-mobile-logo-preview_titlepill {height:calc(7 * var(--tool-mobile-logo-preview-unit));background:#d4d4d8;border-radius:999px;width:46%;}' +
        '.tool-mobile-logo-preview_titlepill--secondary {height:calc(6 * var(--tool-mobile-logo-preview-unit));background:#e3e3e6;width:60%;}' +
        '.tool-mobile-logo-preview_form {display:flex;flex-direction:column;gap:calc(15 * var(--tool-mobile-logo-preview-unit));}' +
        '.tool-mobile-logo-preview_field {display:flex;align-items:center;justify-content:space-between;padding-bottom:calc(8 * var(--tool-mobile-logo-preview-unit));border-bottom:1px solid #e4e4e7;}' +
        '.tool-mobile-logo-preview_fieldhint {width:34%;height:calc(6 * var(--tool-mobile-logo-preview-unit));background:#d4d4d8;border-radius:999px;}' +
        '.tool-mobile-logo-preview_fieldhint--short {width:28%;}' +
        '.tool-mobile-logo-preview_eye {font-size:calc(10 * var(--tool-mobile-logo-preview-unit));color:#6c5ce7;}' +
        '.tool-mobile-logo-preview_loginbtn {height:calc(24 * var(--tool-mobile-logo-preview-unit));border-radius:calc(6 * var(--tool-mobile-logo-preview-unit));background:#4b4bd6;display:flex;align-items:center;justify-content:center;margin-top:calc(2 * var(--tool-mobile-logo-preview-unit));margin-bottom:calc(12 * var(--tool-mobile-logo-preview-unit));}' +
        '.tool-mobile-logo-preview_btnlabel {width:30%;height:calc(5 * var(--tool-mobile-logo-preview-unit));background:rgba(255,255,255,0.9);border-radius:999px;}' +
        '.tool-mobile-system-alert-animation:hover .tool-mobile-logo-preview_brand,.tool-mobile-system-alert-wrapper.tool-mobile-system-alert--active .tool-mobile-logo-preview_brand {animation-play-state:running;}' +
        '@keyframes tool-mobile-logo-preview-swap {0%{opacity:0;transform:scale(0.94);}5%{opacity:1;transform:scale(1);}30%{opacity:1;transform:scale(1);}36%{opacity:0;transform:scale(0.94);}100%{opacity:0;transform:scale(0.94);}}' +
        '@media (max-width: 991.98px) {.tool-mobile-system-alert-animation {height:calc(155 * var(--tool-mobile-logo-preview-unit));padding:calc(10 * var(--tool-mobile-logo-preview-unit)) calc(6 * var(--tool-mobile-logo-preview-unit)) 0;}.tool-mobile-logo-preview_phone {width:calc(228 * var(--tool-mobile-logo-preview-unit));transform:translateY(calc(140 * var(--tool-mobile-logo-preview-unit)));}}' +
        '@media (prefers-reduced-motion: reduce) {.tool-mobile-logo-preview_brand {animation:none !important;}.tool-mobile-logo-preview_brand--a {opacity:1;}}';
    document.head.appendChild(style);

    document.querySelectorAll('.tool-mobile-system-alert-wrapper').forEach(function(wrapper) {
        var trigger = wrapper.querySelector('.tool-mobile-system-alert-trigger');
        if (!trigger) {
            return;
        }

        trigger.addEventListener('focus', function() {
            wrapper.classList.add('tool-mobile-system-alert--active');
        });
        trigger.addEventListener('blur', function() {
            wrapper.classList.remove('tool-mobile-system-alert--active');
        });
    });
})();
{{/js}}