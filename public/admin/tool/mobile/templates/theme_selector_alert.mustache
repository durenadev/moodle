{{!
    @template tool_mobile/theme_selector_alert

    Theme selector alert with a right-side branding customisation animation.

    Context variables required for this template:
    * iconclass Font Awesome icon classes.
    * title Alert title.
    * message Alert body.
    * buttonstr Button text.
    * buttonurl Button URL.

    Example context (json):
    {
        "iconclass": "fa-solid fa-palette",
        "title": "Customise the Moodle app with your brand colours",
        "message": "You are customising how your site looks. With a Premium plan, you can apply your own colours to the Moodle app too.",
        "buttonstr": "Learn more",
        "buttonurl": "https://example.com/admin/tool/mobile/subscription.php"
    }
}}
<div class="card border rounded-4 overflow-hidden mt-5 tool-mobile-theme-selector-alert-wrapper">
    <div class="row g-0 align-items-stretch">
        <div class="col-12 col-lg-7 py-5 px-5 tool-mobile-theme-selector-alert-content bg-primary bg-opacity-10">
            <div class="d-flex align-items-center gap-3 mb-3">
                <i class="{{iconclass}} flex-shrink-0 text-primary fs-5" aria-hidden="true"></i>
                <div class="fs-6 mb-0">{{title}}</div>
            </div>
            <div class="mb-3 small text-body">{{message}}</div>
            {{#buttonstr}}
            <a href="{{buttonurl}}" class="btn btn-primary tool-mobile-theme-selector-alert-trigger">{{buttonstr}}</a>
            {{/buttonstr}}
        </div>
        <div class="col-12 col-lg-5 text-center d-flex">
            <div class="tool-mobile-theme-selector-alert-animation">
                {{> tool_mobile/branding_preview_customisation}}
            </div>
        </div>
    </div>
</div>

